{
  "name": "@kajillion/graph",
  "version": "0.1.0-pre.0",
  "description": "Render a kajillion nodes in your browser. GPU force graph engine. Fork of cosmos.gl.",
  "jsdelivr": "dist/index.min.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": "git://github.com/JohnnyDangerously/kajillion.git",
  "type": "module",
  "files": [
    "dist",
    "CITATION.cff"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "build": "vite build --mode es && vite build --mode umd",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache ./src --ext .ts --ignore-path .gitignore",
    "lint:staged": "npx lint-staged",
    "check:source-size": "node scripts/check-source-size.mjs",
    "check:wgsl": "node scripts/check-wgsl.mjs",
    "check:build": "npm run build && npm run demo:build && npm run bench:build",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "bench:dev": "vite --config benchmarks/vite.config.ts",
    "bench:build": "vite build --config benchmarks/vite.config.ts",
    "demo:dev": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts",
    "demo:preview": "vite preview --config demo/vite.config.ts --port 4174 --strictPort",
    "agent:map": "node scripts/agent-map.mjs map",
    "agent:symbols": "node scripts/agent-map.mjs symbols",
    "agent:range": "node scripts/agent-map.mjs range",
    "agent:owners": "node scripts/agent-map.mjs owners",
    "agent:find": "node scripts/agent-map.mjs find",
    "verify:fast": "node scripts/verify-fast.mjs",
    "verify": "npm run check:source-size && npm run check:wgsl && npm run typecheck && npm run agent:map && npm run build && npm run demo:build && npm run bench:build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=7.0.0"
  },
  "keywords": [
    "graph",
    "webgl",
    "force",
    "simulation",
    "visualization"
  ],
  "homepage": "https://github.com/JohnnyDangerously/kajillion",
  "author": "Kajillion Contributors",
  "devDependencies": {
    "@interacta/css-labels": "^0.6.0",
    "@jls-digital/storybook-addon-code": "^1.0.4",
    "@storybook/addon-essentials": "^8.4.5",
    "@storybook/addon-interactions": "^8.4.5",
    "@storybook/blocks": "^8.4.5",
    "@storybook/html": "^8.4.5",
    "@storybook/html-vite": "^8.4.5",
    "@storybook/test": "^8.4.5",
    "@types/d3-array": "^3.0.3",
    "@types/d3-color": "^3.1.0",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-ease": "^3.0.0",
    "@types/d3-scale": "^4.0.2",
    "@types/d3-scale-chromatic": "^3.0.3",
    "@types/d3-selection": "^3.0.2",
    "@types/d3-transition": "^3.0.1",
    "@types/dompurify": "^3.0.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@webgpu/types": "^0.1.70",
    "d3-scale-chromatic": "^3.1.0",
    "esbuild": "^0.25.3",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-storybook": "^0.11.1",
    "eslint-plugin-unicorn": "^43.0.1",
    "lint-staged": "^13.0.3",
    "pre-commit": "^1.2.2",
    "remark-gfm": "^4.0.0",
    "storybook": "^8.4.5",
    "typescript": "^5.5.2",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.3.0",
    "wgsl_reflect": "^1.3.0"
  },
  "dependencies": {
    "@luma.gl/core": "~9.2.6",
    "@luma.gl/engine": "~9.2.6",
    "@luma.gl/shadertools": "~9.2.6",
    "@luma.gl/webgl": "~9.2.6",
    "@luma.gl/webgpu": "9.2.6",
    "d3-array": "^3.2.0",
    "d3-color": "^3.1.0",
    "d3-drag": "^3.0.0",
    "d3-ease": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "dompurify": "^3.2.6",
    "gl-bench": "^1.0.42",
    "gl-matrix": "^3.4.3",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "random": "^4.1.0",
    "three": "^0.184.0"
  },
  "pre-commit": "lint:staged",
  "lint-staged": {
    "*": "node scripts/verify-fast.mjs"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
